---
import Layout from "../layouts/Layout.astro";

const galleryItems = [
	{ src: "/images/gig-1.jpeg", caption: "Live set" },
	{ src: "/images/gig-2.jpeg", caption: "Stage lights" },
	{ src: "/images/gig-3.jpeg", caption: "Crowd energy" },
	{ src: "/images/gig-4.jpeg", caption: "On stage" },
	{ src: "/images/gig-5.jpeg", caption: "Guitar break" },
	{ src: "/images/gig-6.jpeg", caption: "Full volume" },
	{ src: "/images/gig-7.jpeg", caption: "Late show" },
	{ src: "/images/gig-8.jpeg", caption: "Soundcheck" },
	{ src: "/images/gig-9.jpeg", caption: "Encore" },
	{ src: "/images/gig-10.jpeg", caption: "Band moment" },
	{ src: "/images/gig-11.jpeg", caption: "Venue night" },
	{ src: "/images/gig-12.jpeg", caption: "Final chord" },
	{ src: "/images/gig-13.jpeg", caption: "Backstage" },
];
---

<Layout>
	<main class="site-shell">
		<section class="hero" aria-labelledby="hero-title">
			<div class="hero-copy">
				<p class="eyebrow">Atlit rock band</p>
				<h1 id="hero-title">Aliat Gag</h1>
				<p class="tagline">Raw guitars, loud choruses, and live shows built for the last row.</p>
				<div class="hero-actions" aria-label="Primary actions">
					<a href="#booking" class="button button-primary">Book the band</a>
					<a href="#gallery" class="button button-secondary">View gallery</a>
				</div>
			</div>

			<div class="hero-image">
				<img src="/images/hero.jpeg" alt="Aliat Gag band hero photo" fetchpriority="high" />
			</div>
		</section>

		<section class="section about" aria-labelledby="about-title">
			<div class="section-label">About us</div>
			<div class="about-panel">
				<h2 id="about-title">A compact stage act with a full-size sound.</h2>
				<p>
					Aliat Gag brings the loud guitars, big choruses, and rough-edged energy of 90s rock to the stage. We play the songs people still shout back from the first row, with a live show built for pubs, clubs, private events, and festival slots.
				</p>
			</div>
		</section>

		<section class="section booking" id="booking" aria-labelledby="booking-title">
			<div class="section-label">Book us</div>
			<div class="booking-grid">
				<div class="booking-copy">
					<h2 id="booking-title">Bring Aliat Gag to your next show.</h2>
					<p>
						Tell us about the event, date, and vibe. We will use your request to
          follow up through Wix CRM and keep the gig details attached to your
          contact record.
					</p>					
				</div>

				<form class="booking-form" aria-label="Booking form">
					<label>
						Name
						<input type="text" name="name" placeholder="Your name" />
					</label>
					<label>
						Email
						<input type="email" name="email" placeholder="you@example.com" />
					</label>
					<label>
						Event date
						<input type="date" name="event-date" />
					</label>
					<label>
						Message
						<textarea name="message" rows="5" placeholder="Tell us about the event"></textarea>
					</label>
					<button type="button">Send request</button>
				</form>
			</div>
		</section>

		<section class="section gallery-section" id="gallery" aria-labelledby="gallery-title">
			<div class="section-label">Gallery</div>
			<h2 id="gallery-title">Live moments</h2>
			<div class="gallery-grid">
				{
					galleryItems.map(({ src, caption }) => (
						<figure class="gallery-card">
							<div class="gallery-image">
								<img src={src} alt={`Aliat Gag ${caption.toLowerCase()} photo`} loading="lazy" />
							</div>
						</figure>
					))
				}
			</div>
		</section>
	</main>
</Layout>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	:global(body) {
		background: #12100e;
		color: #f5efe6;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
	}

	.site-shell {
		min-height: 100vh;
		background:
			linear-gradient(rgba(18, 16, 14, 0.68), rgba(18, 16, 14, 0.94)),
			url("/images/hero.jpeg") center / cover fixed;
	}

	.hero,
	.section {
		width: min(1120px, calc(100% - 40px));
		margin: 0 auto;
	}

	.hero {
		min-height: 92vh;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
		gap: clamp(48px, 8vw, 104px);
		align-items: center;
		padding: 56px 0 40px;
	}

	.hero-copy {
		border-top: 2px solid rgba(245, 239, 230, 0.74);
		border-bottom: 2px solid rgba(245, 239, 230, 0.24);
		container-type: inline-size;
		min-width: 0;
		padding: 34px 0;
	}

	.eyebrow,
	.section-label {
		color: #f0c66d;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	h1,
	h2,
	p {
		margin: 0;
	}

	h1 {
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(4rem, 22cqw, 7.1rem);
		line-height: 0.82;
		margin: 14px 0 24px;
		max-width: 100%;
		text-transform: uppercase;
	}

	h2 {
		font-size: clamp(2rem, 4vw, 4rem);
		line-height: 1;
		max-width: 850px;
		text-transform: uppercase;
	}

	p {
		color: #d8cec0;
		font-size: 1.05rem;
		line-height: 1.7;
	}

	.tagline {
		max-width: 520px;
		font-size: clamp(1.18rem, 2vw, 1.55rem);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 28px;
	}

	.button,
	.booking-form button {
		border: 1px solid rgba(245, 239, 230, 0.42);
		border-radius: 3px;
		cursor: pointer;
		font: inherit;
		font-weight: 800;
		padding: 13px 18px;
		text-decoration: none;
		text-transform: uppercase;
		transition:
			background 160ms ease,
			color 160ms ease,
			border-color 160ms ease;
	}

	.button-primary,
	.booking-form button {
		background: #f0c66d;
		border-color: #f0c66d;
		color: #16120f;
	}

	.button-secondary {
		background: rgba(18, 16, 14, 0.54);
		color: #f5efe6;
	}

	.button:hover,
	.booking-form button:hover {
		background: #f5efe6;
		border-color: #f5efe6;
		color: #16120f;
	}

	.hero-image,
	.gallery-image {
		border: 2px solid rgba(245, 239, 230, 0.56);
		background: rgba(18, 16, 14, 0.84);
	}

	.hero-image {
		min-height: 500px;
		aspect-ratio: 1.05;
		justify-self: end;
		width: 100%;
		position: relative;
		overflow: hidden;
	}

	.hero-image::before,
	.gallery-image::before {
		content: "";
		position: absolute;
		inset: 14px;
		border: 1px solid rgba(245, 239, 230, 0.24);
		pointer-events: none;
	}

	.hero-image img,
	.gallery-image img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.hero-image img {
		filter: saturate(1.05) contrast(1.08);
	}

	.section {
		padding: 74px 0;
	}

	.section-label {
		margin-bottom: 18px;
	}

	.about-panel {
		border: 2px solid rgba(245, 239, 230, 0.42);
		padding: clamp(24px, 5vw, 48px);
		background: rgba(18, 16, 14, 0.7);
	}

	.about-panel p {
		max-width: 900px;
		margin-top: 24px;
	}

	.booking-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 0.82fr);
		border: 2px solid rgba(245, 239, 230, 0.42);
		background: rgba(18, 16, 14, 0.76);
	}

	.booking-copy,
	.booking-form {
		padding: clamp(22px, 4vw, 42px);
	}

	.booking-copy {
		border-right: 2px solid rgba(245, 239, 230, 0.28);
	}

	.booking-copy p {
		margin-top: 22px;
	}

	.booking-copy ul {
		display: grid;
		gap: 12px;
		margin: 28px 0 0;
		padding-left: 20px;
		color: #eadfce;
		line-height: 1.55;
	}

	.booking-form {
		display: grid;
		gap: 16px;
	}

	label {
		display: grid;
		gap: 8px;
		color: #f5efe6;
		font-size: 0.86rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	input,
	textarea {
		width: 100%;
		border: 1px solid rgba(245, 239, 230, 0.32);
		border-radius: 2px;
		background: #f5efe6;
		color: #16120f;
		font: inherit;
		padding: 12px 13px;
	}

	textarea {
		resize: vertical;
	}

	input::placeholder,
	textarea::placeholder {
		color: rgba(22, 18, 15, 0.52);
	}

	input[type="date"] {
		color-scheme: light;
	}

	.gallery-section h2 {
		margin-bottom: 28px;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 22px;
	}

	.gallery-card {
		margin: 0;
	}

	.gallery-image {
		aspect-ratio: 1.18;
		position: relative;
		overflow: hidden;
	}

	@media (max-width: 1040px) {
		h1 {
			font-size: clamp(4rem, 18vw, 7rem);
		}

		.hero {
			grid-template-columns: 1fr;
			gap: 36px;
			min-height: auto;
		}

		.hero-image {
			justify-self: stretch;
			min-height: 420px;
		}
	}

	@media (max-width: 820px) {
		.hero,
		.booking-grid {
			grid-template-columns: 1fr;
		}

		.hero {
			min-height: auto;
			padding-top: 32px;
		}

		.hero-image {
			min-height: 340px;
			aspect-ratio: 1;
			justify-self: stretch;
		}

		.booking-copy {
			border-right: 0;
			border-bottom: 2px solid rgba(245, 239, 230, 0.28);
		}

		.gallery-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.hero,
		.section {
			width: min(100% - 28px, 1120px);
		}

		.hero-actions {
			display: grid;
		}

		.gallery-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
