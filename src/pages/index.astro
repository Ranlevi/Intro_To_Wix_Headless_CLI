---
import Layout from "../layouts/Layout.astro";

const galleryItems = [
	{ src: "/images/gig-1.jpeg", alt: "Aliat Gag live set photo" },
	{ src: "/images/gig-2.jpeg", alt: "Aliat Gag stage lights photo" },
	{ src: "/images/gig-3.jpeg", alt: "Aliat Gag crowd energy photo" },
	{ src: "/images/gig-4.jpeg", alt: "Aliat Gag on stage photo" },
	{ src: "/images/gig-5.jpeg", alt: "Aliat Gag guitar break photo" },
	{ src: "/images/gig-6.jpeg", alt: "Aliat Gag full volume photo" },
	{ src: "/images/gig-7.jpeg", alt: "Aliat Gag late show photo" },
	{ src: "/images/gig-8.jpeg", alt: "Aliat Gag soundcheck photo" },
	{ src: "/images/gig-9.jpeg", alt: "Aliat Gag encore photo" },
	{ src: "/images/gig-10.jpeg", alt: "Aliat Gag band moment photo" },
	{ src: "/images/gig-11.jpeg", alt: "Aliat Gag venue night photo" },
	{ src: "/images/gig-12.jpeg", alt: "Aliat Gag final chord photo" },
	{ src: "/images/gig-13.jpeg", alt: "Aliat Gag backstage photo" },
];
---

<Layout>
	<main class="site-shell">
		<section class="hero" aria-labelledby="hero-title">
			<div class="hero-copy">
				<p class="eyebrow">Atlit rock band</p>
				<h1 id="hero-title">Aliat Gag</h1>
				<p class="tagline">Raw guitars, loud choruses, and live shows built for the last row.</p>
				<div class="hero-actions" aria-label="Primary actions">
					<a href="#booking" class="button button-primary">Book the band</a>
					<a href="#gallery" class="button button-secondary">View gallery</a>
				</div>
			</div>

			<div class="hero-image">
				<img src="/images/hero.jpeg" alt="Aliat Gag band hero photo" fetchpriority="high" />
			</div>
		</section>

		<section class="section about" aria-labelledby="about-title">
			<div class="section-label">About us</div>
			<div class="about-panel">
				<h2 id="about-title">A compact stage act with a full-size sound.</h2>
				<p>
					Aliat Gag brings the loud guitars, big choruses, and rough-edged energy of 90s rock to the stage. We play the songs people still shout back from the first row, with a live show built for pubs, clubs, private events, and festival slots.
				</p>
			</div>
		</section>

		<section class="section booking" id="booking" aria-labelledby="booking-title">
			<div class="section-label">Book us</div>
			<div class="booking-grid">
				<div class="booking-copy">
					<h2 id="booking-title">Bring Aliat Gag to your next show.</h2>
					<p>
						Tell us about the event, date, and vibe. We will use your request to
						follow up through Wix CRM and keep the gig details attached to your
						contact record.
					</p>
				</div>

				<form
					class="booking-form"
					action="/api/book-gig"
					method="post"
					aria-label="Booking form"
					data-booking-form
					novalidate
				>
					<label>
						Name
						<input type="text" name="name" placeholder="Your name" required />
					</label>
					<label>
						Email
						<input type="email" name="email" placeholder="you@example.com" required />
					</label>
					<label>
						Event date
						<input type="date" name="event-date" required />
					</label>
					<label>
						Message
						<textarea
							name="message"
							rows="5"
							placeholder="Tell us about the event"
							required></textarea>
					</label>
					<button type="submit">Send request</button>
					<p class="form-status" data-booking-status role="status" aria-live="polite"></p>
				</form>
			</div>
		</section>

		<section class="section gallery-section" id="gallery" aria-labelledby="gallery-title">
			<div class="section-label">Gallery</div>
			<h2 id="gallery-title">Live moments</h2>
			<div class="gallery-grid">
				{
					galleryItems.map(({ src, alt }) => (
						<figure class="gallery-card">
							<div class="gallery-image">
								<img src={src} alt={alt} loading="lazy" />
							</div>
						</figure>
					))
				}
			</div>
		</section>
	</main>
</Layout>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	:global(body) {
		background: #12100e;
		color: #f5efe6;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
	}

	.site-shell {
		min-height: 100vh;
		background:
			linear-gradient(rgba(18, 16, 14, 0.68), rgba(18, 16, 14, 0.94)),
			url("/images/hero.jpeg") center / cover fixed;
	}

	.hero,
	.section {
		width: min(1120px, calc(100% - 40px));
		margin: 0 auto;
	}

	.hero {
		min-height: 92vh;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
		gap: clamp(48px, 8vw, 104px);
		align-items: center;
		padding: 56px 0 40px;
	}

	.hero-copy {
		border-top: 2px solid rgba(245, 239, 230, 0.74);
		border-bottom: 2px solid rgba(245, 239, 230, 0.24);
		container-type: inline-size;
		min-width: 0;
		padding: 34px 0;
	}

	.eyebrow,
	.section-label {
		color: #f0c66d;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	h1,
	h2,
	p {
		margin: 0;
	}

	h1 {
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(4rem, 22cqw, 7.1rem);
		line-height: 0.82;
		margin: 14px 0 24px;
		max-width: 100%;
		text-transform: uppercase;
	}

	h2 {
		font-size: clamp(2rem, 4vw, 4rem);
		line-height: 1;
		max-width: 850px;
		text-transform: uppercase;
	}

	p {
		color: #d8cec0;
		font-size: 1.05rem;
		line-height: 1.7;
	}

	.tagline {
		max-width: 520px;
		font-size: clamp(1.18rem, 2vw, 1.55rem);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 28px;
	}

	.button,
	.booking-form button {
		border: 1px solid rgba(245, 239, 230, 0.42);
		border-radius: 3px;
		cursor: pointer;
		font: inherit;
		font-weight: 800;
		padding: 13px 18px;
		text-decoration: none;
		text-transform: uppercase;
		transition:
			background 160ms ease,
			color 160ms ease,
			border-color 160ms ease;
	}

	.button-primary,
	.booking-form button {
		background: #f0c66d;
		border-color: #f0c66d;
		color: #16120f;
	}

	.button-secondary {
		background: rgba(18, 16, 14, 0.54);
		color: #f5efe6;
	}

	.button:hover,
	.booking-form button:hover {
		background: #f5efe6;
		border-color: #f5efe6;
		color: #16120f;
	}

	.booking-form button:disabled {
		cursor: wait;
		opacity: 0.64;
	}

	.hero-image,
	.gallery-image {
		border: 2px solid rgba(245, 239, 230, 0.56);
		background: rgba(18, 16, 14, 0.84);
	}

	.hero-image {
		min-height: 500px;
		aspect-ratio: 1.05;
		justify-self: end;
		width: 100%;
		position: relative;
		overflow: hidden;
	}

	.hero-image::before,
	.gallery-image::before {
		content: "";
		position: absolute;
		inset: 14px;
		border: 1px solid rgba(245, 239, 230, 0.24);
		pointer-events: none;
	}

	.hero-image img,
	.gallery-image img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.hero-image img {
		filter: saturate(1.05) contrast(1.08);
	}

	.section {
		padding: 74px 0;
	}

	.section-label {
		margin-bottom: 18px;
	}

	.about-panel {
		border: 2px solid rgba(245, 239, 230, 0.42);
		padding: clamp(24px, 5vw, 48px);
		background: rgba(18, 16, 14, 0.7);
	}

	.about-panel p {
		max-width: 900px;
		margin-top: 24px;
	}

	.booking-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 0.82fr);
		border: 2px solid rgba(245, 239, 230, 0.42);
		background: rgba(18, 16, 14, 0.76);
	}

	.booking-copy,
	.booking-form {
		padding: clamp(22px, 4vw, 42px);
	}

	.booking-copy {
		border-right: 2px solid rgba(245, 239, 230, 0.28);
	}

	.booking-copy p {
		margin-top: 22px;
	}

	.booking-form {
		display: grid;
		gap: 16px;
	}

	label {
		display: grid;
		gap: 8px;
		color: #f5efe6;
		font-size: 0.86rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	input,
	textarea {
		width: 100%;
		border: 1px solid rgba(245, 239, 230, 0.32);
		border-radius: 2px;
		background: #f5efe6;
		color: #16120f;
		font: inherit;
		padding: 12px 13px;
	}

	textarea {
		resize: vertical;
	}

	input::placeholder,
	textarea::placeholder {
		color: rgba(22, 18, 15, 0.52);
	}

	input[type="date"] {
		color-scheme: light;
	}

	.form-status {
		min-height: 1.5em;
		color: #f0c66d;
		font-size: 0.95rem;
		font-weight: 800;
		line-height: 1.5;
	}

	.form-status[data-status="success"] {
		color: #b7e083;
	}

	.form-status[data-status="error"] {
		color: #ff9b8f;
	}

	.gallery-section h2 {
		margin-bottom: 28px;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 22px;
	}

	.gallery-card {
		margin: 0;
	}

	.gallery-image {
		aspect-ratio: 1.18;
		position: relative;
		overflow: hidden;
	}

	@media (max-width: 1040px) {
		h1 {
			font-size: clamp(4rem, 18vw, 7rem);
		}

		.hero {
			grid-template-columns: 1fr;
			gap: 36px;
			min-height: auto;
		}

		.hero-image {
			justify-self: stretch;
			min-height: 420px;
		}
	}

	@media (max-width: 820px) {
		.hero,
		.booking-grid {
			grid-template-columns: 1fr;
		}

		.hero {
			min-height: auto;
			padding-top: 32px;
		}

		.hero-image {
			min-height: 340px;
			aspect-ratio: 1;
			justify-self: stretch;
		}

		.booking-copy {
			border-right: 0;
			border-bottom: 2px solid rgba(245, 239, 230, 0.28);
		}

		.gallery-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.hero,
		.section {
			width: min(100% - 28px, 1120px);
		}

		.hero-actions {
			display: grid;
		}

		.gallery-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	const bookingForm   = document.querySelector("[data-booking-form]");
	const bookingStatus = document.querySelector("[data-booking-status]");

	const setBookingStatus = (message, type = "neutral") => {
		//Safey check
		if (!(bookingStatus instanceof HTMLElement)) {
			return;
		}

		//Store the statue message and type (success/error)
		bookingStatus.textContent = message;
		bookingStatus.dataset.status = type;
	};

	if (bookingForm instanceof HTMLFormElement) {
		const submitButton = bookingForm.querySelector("button[type='submit']");

		bookingForm.addEventListener("submit", async (event) => {

			event.preventDefault();

			//Check required fields are not empty, email is valid.
			//If the form is not valid, show a custom message, then ask
			//the browser to point out the speicific invalid field.
			if (!bookingForm.checkValidity()) {
				setBookingStatus("Please fill the missing information.", "error");
				bookingForm.reportValidity();
				return;
			}

			//Disable the submit button to prevent sending the form twice.
			if (submitButton instanceof HTMLButtonElement) {
				submitButton.disabled = true;
			}

			setBookingStatus("Sending booking request...");

			try {
				//Send the form data to the API endpoint.
				//The action sends the POST request to /api/book-gig
				//Creates a FormData object from the form's fields.
				//Pause until the server responds.
				const response = await fetch(bookingForm.action, {
					method: "POST",
					body: new FormData(bookingForm),
				});

				//Parsing the response as JSON. If the response is not
				//a valid JSON, use an empty object instead of crashing.
				const result = await response.json().catch(() => ({}));

				if (response.ok && result.ok) {
					bookingForm.reset();
					setBookingStatus("Booking request sent.", "success");
					return;
				}

				if (response.status === 400) {
					setBookingStatus("Please fill the missing information.", "error");
					return;
				}

				setBookingStatus("Something went wrong. Please try again.", "error");
			} catch {
				setBookingStatus("Something went wrong. Please try again.", "error");
			} finally {
				if (submitButton instanceof HTMLButtonElement) {
					submitButton.disabled = false;
				}
			}
		});
	}
</script>
